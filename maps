/*LinkedHashMap estende o HashMap, por manutenção de lista.
new LinkedHashMap() - novo LinkedHashMap
put() - insere item
remove() - remove item
containsKey() - retorna chave
containsValues() - retorna valores*/

public class Principal{
  public static void main (String[] args){

    LinkedHashMap <String, String> listaNomes = new LinkedHashMap<>();
    listaNomes.put ("Lari", "Larissa");
    listaNomes.put ("Will", "William");
    listaNomes.put ("Cocoiate", "Vitor");
    System.out.println ("LinkedHashMap:" + listaNomes);

    LinkedHashMap <String, String> novaListaNomes = new LinkedHashMap<> (listaNomes);
    novaListaNomes ("Pipocat", "Pipoca");
    System.out.println ("Nova LinkedHashMap:" + novaListaNomes);
  }
}

/* TreeMap map que mantém as entradas em ordem crescente. 
new TreeMap() - novo TreeMap
put() - insere item
remove() - remove item
containsKey() - retorna chave
containsValues() - retorna valores*/

public class Principal{
  public static void main (String[] args){

    TreeMap <String, String> mapaNomes = new TreeMap<>();
    listaNomes.put ("Lari", "Larissa");
    listaNomes.put ("Will", "William");
    listaNomes.put ("Cocoiate", "Vitor");
    System.out.println ("TreeMap de Nomes:" + mapaaNomes);

    System.out.println ("Chaves:" + mapasNomes.keySet());
    System.out.println ("Valores:" + mapaNomes.values());
    System.out.println ("Chave/valor:" + mapaNomes.entrySet());
  }
}
