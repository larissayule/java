// Incremento e decremento:

import java.util.Scanner;
public class Principal {
    public static void main (String[] args){

        int num1, num2;
        num1 = 6;
        num2 = 6;

        num1++; // num1 = num1 +1, SÓ QUE VINDO O INCREMENTO DEPOIS, ACONTECE PARA A PRÓXIMA INSTRUÇÃO.
        ++num2; // num2 = num2 +1, SÓ QUE VINDO O INCREMENTO ANTES, ACONTECE PARA ESSA INSTRUÇÃO.

        System.out.println(num1); //6
        System.out.println(num2); //6

        System.out.println(num1++); //6
        System.out.println(++num2); //7
    }
}

